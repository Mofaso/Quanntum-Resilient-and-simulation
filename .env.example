## Backend
ENVIRONMENT=dev
FRONTEND_URL=http://localhost:5173

# For Postgres (recommended for production)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/quantum_defense

JWT_ISSUER=aqr-cads
JWT_AUDIENCE=aqr-cads-desktop
JWT_SECRET=CHANGE_ME_DEV_ONLY
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=14

# 32-byte random key, base64 encoded (required in prod)
# Example generation (PowerShell):
#   [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Max 256}))
VAULT_MASTER_KEY_B64=

## Frontend
VITE_API_BASE_URL=http://localhost:18000

